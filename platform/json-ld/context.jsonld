{
  "@context": {
    "@version": 1.1,
    "uod": "https://w3id.org/uod/core/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "id": "@id",
    "type": "@type",

    "Entity": "uod:Entity",
    "Party": "uod:Party",
    "Person": "uod:Person",
    "Organization": "uod:Organization",
    "OrgUnit": "uod:OrgUnit",

    "Resource": "uod:Resource",
    "ProductService": "uod:ProductService",
    "Asset": "uod:Asset",
    "DataObject": "uod:DataObject",
    "Document": "uod:Document",
    "SystemApplication": "uod:SystemApplication",

    "Governance": "uod:Governance",
    "Policy": "uod:Policy",
    "Rule": "uod:Rule",
    "Control": "uod:Control",
    "Risk": "uod:Risk",

    "Operational": "uod:Operational",
    "Role": "uod:Role",
    "Capability": "uod:Capability",
    "Process": "uod:Process",
    "Event": "uod:Event",

    "Measurement": "uod:Measurement",
    "Goal": "uod:Goal",
    "KPI": "uod:KPI",

    "label": "rdfs:label",
    "label_zh": { "@id": "rdfs:label", "@language": "zh" },
    "label_en": { "@id": "rdfs:label", "@language": "en" },
    "definition": { "@id": "rdfs:comment", "@language": "zh" },
    "definition_en": { "@id": "rdfs:comment", "@language": "en" },
    "parent": { "@id": "rdfs:subClassOf", "@type": "@id" },

    "plays_role": { "@id": "uod:plays_role", "@type": "@id" },
    "part_of": { "@id": "uod:part_of", "@type": "@id" },
    "owns": { "@id": "uod:owns", "@type": "@id" },
    "accountable_for": { "@id": "uod:accountable_for", "@type": "@id" },
    "realized_by": { "@id": "uod:realized_by", "@type": "@id" },
    "consumes": { "@id": "uod:consumes", "@type": "@id" },
    "produces": { "@id": "uod:produces", "@type": "@id" },
    "recorded_in": { "@id": "uod:recorded_in", "@type": "@id" },
    "governed_by": { "@id": "uod:governed_by", "@type": "@id" },
    "mitigated_by": { "@id": "uod:mitigated_by", "@type": "@id" },
    "triggered_by": { "@id": "uod:triggered_by", "@type": "@id" },
    "measured_by": { "@id": "uod:measured_by", "@type": "@id" }
  }
}
