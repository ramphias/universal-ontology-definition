    rdfs:label "Universal Enterprise Ontology Core"@en ;
    rdfs:label "适用于所有企业的组织通用 ontology 核心，定义了跨行业、跨企业的核心概念、关系与实例。v2.0 引入抽象域根类、泛型关系与版本演进机制。"@zh ;
    owl:versionInfo "2.1.0" .

