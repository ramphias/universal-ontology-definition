# ────────────────────────────────────────
# AXIOMS (OWL 2 Semantic Constraints)
# ────────────────────────────────────────

# ax_person_org_disjoint: An instance cannot be both a Person and an Organization
uod:Person owl:disjointWith uod:Organization .

# ax_entity_governance_disjoint: Entity domain and Governance domain instances are mutually exclusive
uod:Entity owl:disjointWith uod:Governance .

# ax_entity_operational_disjoint: Entity domain and Operational domain instances are mutually exclusive
uod:Entity owl:disjointWith uod:Operational .

# ax_entity_measurement_disjoint: Entity domain and Measurement domain instances are mutually exclusive
uod:Entity owl:disjointWith uod:Measurement .

# ax_governance_operational_disjoint: Governance domain and Operational domain instances are mutually exclusive
uod:Governance owl:disjointWith uod:Operational .

# ax_governance_measurement_disjoint: Governance domain and Measurement domain instances are mutually exclusive
uod:Governance owl:disjointWith uod:Measurement .

# ax_operational_measurement_disjoint: Operational domain and Measurement domain instances are mutually exclusive
uod:Operational owl:disjointWith uod:Measurement .

# ax_policy_rule_disjoint: An instance cannot be both a Policy and a Rule
uod:Policy owl:disjointWith uod:Rule .

# ax_part_of_transitive: If A is part of B and B is part of C, then A is part of C
uod:part_of a owl:TransitiveProperty .

# ax_part_of_asymmetric: If A is part of B, then B cannot be part of A
uod:part_of a owl:AsymmetricProperty .

# ax_owns_domain_party: The owns relation is restricted to Party subclasses as domain and Resource subclasses as range
uod:Party rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:owns ;
    owl:allValuesFrom uod:Resource
] .

# ax_governed_by_range_governance: All objects linked via governed_by must be subclasses of the Governance domain
uod:Operational rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:governed_by ;
    owl:allValuesFrom uod:Governance
] .

# ax_process_realizes_capability: Every Capability is realized by at least one Process
uod:Capability rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:realized_by ;
    owl:someValuesFrom uod:Process
] .

# ax_risk_mitigated_by_control: Every Risk is mitigated by at least one Control measure
uod:Risk rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:mitigated_by ;
    owl:someValuesFrom uod:Control
] .

# ax_kpi_measures_operational: Every KPI is linked to at least one Operational element it measures
uod:KPI rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:measured_by ;
    owl:someValuesFrom uod:Operational
] .

# ax_org_min_one_role: Every Organization plays at least one Role
uod:Organization rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:plays_role ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
] .

# ax_composed_of_sub_part_of: The composition relation is a specialization of the part-of relation
uod:composed_of rdfs:subPropertyOf uod:part_of .

# ax_plays_role_domain_party: Every Role is played by at least one Party
uod:Role rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:plays_role ;
    owl:someValuesFrom uod:Party
] .

# ax_kpi_evaluates_goal: Every KPI evaluates at least one Goal
uod:KPI rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty uod:evaluates ;
    owl:someValuesFrom uod:Goal
] .

