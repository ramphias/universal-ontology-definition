uod-fnb:operates_restaurant a owl:ObjectProperty ;
    rdfs:label "operates restaurant"@en ;
    rdfs:domain uod-fnb:Franchisee ;
    rdfs:range uod-fnb:Restaurant ;
    rdfs:comment "特许经营商出资并主理指定门店"@zh .

uod-fnb:supplies_ingredient a owl:ObjectProperty ;
    rdfs:label "supplies ingredient"@en ;
    rdfs:domain uod-fnb:FoodSupplier ;
    rdfs:range uod-fnb:Ingredient ;
    rdfs:comment "供应商向品牌输送食品原料"@zh .

uod-fnb:managed_by a owl:ObjectProperty ;
    rdfs:label "managed by"@en ;
    rdfs:domain uod-fnb:Restaurant ;
    rdfs:range uod-fnb:StoreManager ;
    rdfs:comment "门店由一位具体的店长全权管理"@zh .

uod-fnb:contains_product a owl:ObjectProperty ;
    rdfs:label "contains product"@en ;
    rdfs:domain uod-fnb:ComboMeal ;
    rdfs:range uod-fnb:MenuProduct ;
    rdfs:comment "实体套餐绑定特定的单品组合"@zh .

uod-fnb:requires_ingredient a owl:ObjectProperty ;
    rdfs:label "requires ingredient"@en ;
    rdfs:domain uod-fnb:MenuProduct ;
    rdfs:range uod-fnb:Ingredient ;
    rdfs:comment "单项成品售卖前需要消耗设定的原料"@zh .

uod-fnb:guided_by_recipe a owl:ObjectProperty ;
    rdfs:label "guided by recipe"@en ;
    rdfs:domain uod-fnb:FoodPreparation ;
    rdfs:range uod-fnb:Recipe ;
    rdfs:comment "制餐过程必须遵循SOP配方的要求与规程"@zh .

uod-fnb:includes_packaging a owl:ObjectProperty ;
    rdfs:label "includes packaging"@en ;
    rdfs:domain uod-fnb:FoodOrder ;
    rdfs:range uod-fnb:TakeawayPackaging ;
    rdfs:comment "外带/外卖订单需要使用配给的包材"@zh .
