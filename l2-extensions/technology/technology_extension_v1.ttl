    rdfs:domain uod-techno:TechCompany ;
    rdfs:range uod-techno:EngineeringTeam ;
    rdfs:comment "A tech company has engineering teams"@en ;
    rdfs:comment "科技公司设有工程团队"@zh .

uod-techno:develops_product a owl:ObjectProperty ;
    rdfs:label "develops product"@en ;
    rdfs:domain uod-techno:EngineeringTeam ;
