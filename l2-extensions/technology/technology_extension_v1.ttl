uod-techno:TechCompany a owl:Class ;
    rdfs:subClassOf uod:Organization ;
    rdfs:label "Technology Company"@en ;
    rdfs:label "科技公司"@zh ;
    rdfs:comment "An enterprise with technology products or platforms as its core business"@en ;
    rdfs:comment "以技术产品或平台为核心业务的企业"@zh .

uod-techno:EngineeringTeam a owl:Class ;
    rdfs:subClassOf uod:OrgUnit ;
    rdfs:label "Engineering Team"@en ;
    rdfs:label "工程团队"@zh ;
    rdfs:comment "An organizational unit responsible for product development and technical delivery"@en ;
    rdfs:comment "负责产品研发和技术交付的工程组织单元"@zh .

uod-techno:SaaSProduct a owl:Class ;
    rdfs:subClassOf uod:ProductService ;
    rdfs:label "SaaS Product"@en ;
    rdfs:label "SaaS 产品"@zh ;
    rdfs:comment "Cloud-based software-as-a-service product delivered via subscription model"@en ;
    rdfs:comment "以订阅模式交付的云端软件即服务产品"@zh .

uod-techno:PlatformService a owl:Class ;
    rdfs:subClassOf uod:ProductService ;
    rdfs:label "Platform Service"@en ;
    rdfs:label "平台服务"@zh ;
    rdfs:comment "Platform products providing foundational capabilities, e.g., API platforms, data platforms, AI platforms"@en ;
    rdfs:comment "为开发者或企业提供基础能力的平台类产品，如 API 平台、数据平台、AI 平台"@zh .

uod-techno:APIEndpoint a owl:Class ;
    rdfs:subClassOf uod:Resource ;
    rdfs:label "API Endpoint"@en ;
    rdfs:label "API 接口"@zh ;
    rdfs:comment "An externally exposed application programming interface endpoint"@en ;
    rdfs:comment "对外暴露的应用程序编程接口端点"@zh .

uod-techno:Microservice a owl:Class ;
    rdfs:subClassOf uod:SystemApplication ;
    rdfs:label "Microservice"@en ;
    rdfs:label "微服务"@zh ;
    rdfs:comment "A fine-grained service unit that can be independently deployed and scaled"@en ;
    rdfs:comment "独立部署和扩展的细粒度服务单元"@zh .

uod-techno:CloudInfrastructure a owl:Class ;
    rdfs:subClassOf uod:Asset ;
    rdfs:label "Cloud Infrastructure"@en ;
    rdfs:label "云基础设施"@zh ;
    rdfs:comment "Compute, storage, and networking resources running on public or private cloud"@en ;
    rdfs:comment "在公有云或私有云上运行的计算、存储和网络资源"@zh .

uod-techno:DataPipeline a owl:Class ;
    rdfs:subClassOf uod:Process ;
    rdfs:label "Data Pipeline"@en ;
    rdfs:label "数据管道"@zh ;
    rdfs:comment "Automated data flow from ingestion, transformation, to loading into target systems"@en ;
    rdfs:comment "从数据源采集、转换和加载到目标系统的自动化数据流程"@zh .

uod-techno:MLModel a owl:Class ;
    rdfs:subClassOf uod:Asset ;
    rdfs:label "ML Model"@en ;
    rdfs:label "机器学习模型"@zh ;
    rdfs:comment "A trained machine learning model asset used for prediction or classification"@en ;
    rdfs:comment "训练后用于预测或分类的机器学习模型资产"@zh .

uod-techno:Sprint a owl:Class ;
    rdfs:subClassOf uod:Event ;
    rdfs:label "Sprint"@en ;
    rdfs:label "迭代"@zh ;
    rdfs:comment "A fixed time-box work iteration in agile development, typically 1-4 weeks"@en ;
    rdfs:comment "敏捷开发中固定时间窗口的工作迭代，通常 1-4 周"@zh .

uod-techno:FeatureRequest a owl:Class ;
    rdfs:subClassOf uod:Document ;
    rdfs:label "Feature Request"@en ;
    rdfs:label "需求工单"@zh ;
    rdfs:comment "A structured ticket describing a new product feature or enhancement request"@en ;
    rdfs:comment "描述产品新功能或改进需求的结构化工单"@zh .

uod-techno:Incident a owl:Class ;
    rdfs:subClassOf uod:Event ;
    rdfs:label "Incident"@en ;
    rdfs:label "故障事件"@zh ;
    rdfs:comment "An abnormal production event affecting service availability or performance"@en ;
    rdfs:comment "影响服务可用性或性能的生产环境异常事件"@zh .

uod-techno:Deployment a owl:Class ;
    rdfs:subClassOf uod:Event ;
    rdfs:label "Deployment"@en ;
    rdfs:label "部署"@zh ;
    rdfs:comment "An operational event releasing code changes to the production environment"@en ;
    rdfs:comment "将代码变更发布到生产环境的操作事件"@zh .

uod-techno:TechDebt a owl:Class ;
    rdfs:subClassOf uod:Risk ;
    rdfs:label "Technical Debt"@en ;
    rdfs:label "技术债务"@zh ;
    rdfs:comment "Code quality issues accumulated from short-term compromises, increasing future maintenance cost and failure risk"@en ;
    rdfs:comment "因短期妥协积累的代码质量问题，增加未来维护成本和系统故障风险"@zh .

uod-techno:SecurityVulnerability a owl:Class ;
    rdfs:subClassOf uod:Risk ;
    rdfs:label "Security Vulnerability"@en ;
    rdfs:label "安全漏洞"@zh ;
    rdfs:comment "Exploitable weaknesses in systems, e.g., code vulnerabilities, misconfigurations, dependency CVEs"@en ;
    rdfs:comment "系统中可被利用的安全弱点，如代码漏洞、配置错误、依赖库漏洞"@zh .

