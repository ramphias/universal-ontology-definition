    rdfs:comment "A microservice runs on cloud infrastructure"@en ;
    rdfs:comment "微服务运行在云基础设施上"@zh .

uod-techno:trains_model a owl:ObjectProperty ;
    rdfs:label "trains model"@en ;
    rdfs:domain uod-techno:DataPipeline ;
