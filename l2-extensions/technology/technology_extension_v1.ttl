    rdfs:label "产品研发能力"@zh ;
    rdfs:comment "Organizational capability to rapidly iterate and deliver high-quality software products"@en ;
    rdfs:comment "快速迭代和交付高质量软件产品的组织能力"@zh .

uod-techno:ObservabilityPlatform a owl:Class ;
