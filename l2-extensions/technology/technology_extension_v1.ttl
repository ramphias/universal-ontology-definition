uod-techno:Ontology a owl:Ontology ;
    rdfs:label "Technology industry extension covering SaaS products, platfo"@en ;
    rdfs:label "科技行业扩展 ontology，覆盖 SaaS 产品、平台工程、DevOps、AI/ML、云基础设施和技术团队管理"@zh ;
    owl:imports <https://w3id.org/uod/core/> ;
    owl:versionInfo "1.0.0" .

