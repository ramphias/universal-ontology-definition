    rdfs:comment "A platform is composed of microservices"@en ;
    rdfs:comment "平台由微服务组成"@zh .

uod-techno:runs_on a owl:ObjectProperty ;
    rdfs:label "runs on"@en ;
    rdfs:domain uod-techno:Microservice ;
