    rdfs:comment "资金或金融资产的转移事件，含存取款、转账、支付、证券买卖等"@zh .

uod-financ:Claim a owl:Class ;
    rdfs:subClassOf uod:Resource ;
    rdfs:label "Insurance Claim"@en ;
    rdfs:label "理赔"@zh ;
