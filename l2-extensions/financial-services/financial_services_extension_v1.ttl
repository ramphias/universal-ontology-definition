uod-financ:FinancialInstitution a owl:Class ;
    rdfs:subClassOf uod:Organization ;
    rdfs:label "Financial Institution"@en ;
    rdfs:label "金融机构"@zh ;
    rdfs:comment "A licensed entity providing financial services, e.g., banks, insurers, brokerages, fund managers"@en ;
    rdfs:comment "持有牌照的金融服务提供主体，如银行、保险公司、券商、基金公司等"@zh .

uod-financ:BankBranch a owl:Class ;
    rdfs:subClassOf uod:OrgUnit ;
    rdfs:label "Bank Branch"@en ;
    rdfs:label "银行网点"@zh ;
    rdfs:comment "A geographically distributed branch providing in-person banking services"@en ;
    rdfs:comment "银行按地理区域设立的分支网点，提供线下金融服务"@zh .

uod-financ:BusinessLine a owl:Class ;
    rdfs:subClassOf uod:OrgUnit ;
    rdfs:label "Business Line"@en ;
    rdfs:label "业务条线"@zh ;
    rdfs:comment "An operational unit organized by business type, e.g., retail banking, corporate banking, investment banking, wealth management"@en ;
    rdfs:comment "按业务类型划分的经营单元，如零售银行、公司银行、投资银行、财富管理等"@zh .

uod-financ:FinancialProduct a owl:Class ;
    rdfs:subClassOf uod:ProductService ;
    rdfs:label "Financial Product"@en ;
    rdfs:label "金融产品"@zh ;
    rdfs:comment "Standardized or customized products designed and sold by financial institutions, e.g., deposits, loans, funds, insurance policies"@en ;
    rdfs:comment "金融机构设计和销售的标准化或定制化产品，如存款、贷款、基金、保单等"@zh .

uod-financ:LoanProduct a owl:Class ;
    rdfs:subClassOf uod-financ:FinancialProduct ;
    rdfs:label "Loan Product"@en ;
    rdfs:label "贷款产品"@zh ;
    rdfs:comment "Credit products issued to individuals or corporations, including mortgages, consumer loans, and business loans"@en ;
    rdfs:comment "向个人或企业发放信贷的产品，含住房贷款、消费贷、经营贷等"@zh .

uod-financ:InsurancePolicy a owl:Class ;
    rdfs:subClassOf uod-financ:FinancialProduct ;
    rdfs:label "Insurance Policy"@en ;
    rdfs:label "保险产品"@zh ;
    rdfs:comment "Risk transfer products underwritten by insurers, including life, property, health, and liability insurance"@en ;
    rdfs:comment "保险公司承保的风险转移产品，含寿险、财险、健康险、责任险等"@zh .

uod-financ:InvestmentFund a owl:Class ;
