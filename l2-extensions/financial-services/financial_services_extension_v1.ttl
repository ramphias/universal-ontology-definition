    rdfs:label "Investment Fund"@en ;
    rdfs:label "投资基金"@zh ;
    rdfs:comment "Pooled investment vehicles including mutual funds, private equity funds, and ETFs"@en ;
    rdfs:comment "集合投资者资金进行组合投资的产品，含公募基金、私募基金、ETF等"@zh .

uod-financ:CustomerAccount a owl:Class ;
    rdfs:subClassOf uod:Resource ;
    rdfs:label "Customer Account"@en ;
    rdfs:label "客户账户"@zh ;
    rdfs:comment "An account opened for a customer, recording balances, holdings, and transaction history"@en ;
    rdfs:comment "金融机构为客户开立的账户，记录资金、持仓和交易历史"@zh .

uod-financ:Transaction a owl:Class ;
    rdfs:subClassOf uod:Event ;
    rdfs:label "Transaction"@en ;
    rdfs:label "交易"@zh ;
