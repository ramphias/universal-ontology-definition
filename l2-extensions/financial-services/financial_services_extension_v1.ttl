    rdfs:comment "投保人向保险公司提出的损失赔偿请求"@zh .

uod-financ:Portfolio a owl:Class ;
    rdfs:subClassOf uod:Resource ;
    rdfs:label "Investment Portfolio"@en ;
    rdfs:label "投资组合"@zh ;
