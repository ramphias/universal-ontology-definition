uod-financ:CreditRisk a owl:Class ;
    rdfs:subClassOf uod:Risk ;
    rdfs:label "Credit Risk"@en ;
    rdfs:label "信用风险"@zh ;
    rdfs:comment "Risk of loss due to a borrower's or counterparty's failure to meet contractual obligations"@en ;
    rdfs:comment "借款人或交易对手无法履行合约义务导致的损失风险"@zh .

uod-financ:MarketRisk a owl:Class ;
    rdfs:subClassOf uod:Risk ;
    rdfs:label "Market Risk"@en ;
    rdfs:label "市场风险"@zh ;
    rdfs:comment "Risk of loss due to fluctuations in interest rates, exchange rates, equity prices, or commodity prices"@en ;
    rdfs:comment "因利率、汇率、股价、商品价格等市场因素波动导致的损失风险"@zh .

uod-financ:OperationalRisk a owl:Class ;
    rdfs:subClassOf uod:Risk ;
    rdfs:label "Operational Risk"@en ;
    rdfs:label "操作风险"@zh ;
    rdfs:comment "Risk of loss due to inadequate internal processes, people, systems, or external events"@en ;
    rdfs:comment "因内部流程、人员、系统缺陷或外部事件导致的损失风险"@zh .

uod-financ:AMLPolicy a owl:Class ;
