uod-financ:Ontology a owl:Ontology ;
    rdfs:label "Financial Services industry extension covering banking, insu"@en ;
    rdfs:label "金融服务行业扩展 ontology，覆盖银行、保险、资产管理、支付等金融业务领域的核心概念、产品、流程、风险与合规"@zh ;
    owl:imports <https://w3id.org/uod/core/> ;
    owl:versionInfo "1.0.0" .

