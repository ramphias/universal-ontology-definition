# OBJECT PROPERTIES (Relations)
# ────────────────────────────────────────

uod-health:has_department a owl:ObjectProperty ;
    rdfs:label "has department"@en ;
    rdfs:domain uod-health:Hospital ;
    rdfs:range uod-health:ClinicalDepartment ;
    rdfs:comment "A hospital has clinical departments"@en ;
    rdfs:comment "医院设有临床科室"@zh .

uod-health:treats_patient a owl:ObjectProperty ;
    rdfs:label "treats patient"@en ;
    rdfs:domain uod-health:Physician ;
    rdfs:range uod-health:Patient ;
    rdfs:comment "A physician treats a patient"@en ;
    rdfs:comment "医师诊治患者"@zh .

uod-health:prescribes a owl:ObjectProperty ;
    rdfs:label "prescribes"@en ;
    rdfs:domain uod-health:Physician ;
    rdfs:range uod-health:Prescription ;
    rdfs:comment "A physician issues a prescription"@en ;
    rdfs:comment "医师开具处方"@zh .

uod-health:documents_in_ehr a owl:ObjectProperty ;
    rdfs:label "documents in ehr"@en ;
    rdfs:domain uod-health:Diagnosis ;
    rdfs:range uod-health:ElectronicHealthRecord ;
    rdfs:comment "A diagnosis is documented in the electronic health record"@en ;
    rdfs:comment "诊断记录于电子健康档案"@zh .

uod-health:conducted_under_protocol a owl:ObjectProperty ;
    rdfs:label "conducted under protocol"@en ;
    rdfs:domain uod-health:ClinicalTrial ;
    rdfs:range uod-health:ClinicalProtocol ;
    rdfs:comment "A clinical trial is conducted under a clinical protocol"@en ;
    rdfs:comment "临床试验按方案执行"@zh .

uod-health:develops_drug a owl:ObjectProperty ;
    rdfs:label "develops drug"@en ;
    rdfs:domain uod-health:PharmaceuticalCompany ;
    rdfs:range uod-health:DrugProduct ;
    rdfs:comment "A pharmaceutical company develops a drug product"@en ;
    rdfs:comment "制药企业研发药品"@zh .

uod-health:submitted_for_approval a owl:ObjectProperty ;
    rdfs:label "submitted for approval"@en ;
    rdfs:domain uod-health:DrugProduct ;
    rdfs:range uod-health:RegulatorySubmission ;
    rdfs:comment "A drug product is submitted for regulatory approval"@en ;
    rdfs:comment "药品提交注册申报"@zh .

uod-health:managed_in_his a owl:ObjectProperty ;
    rdfs:label "managed in his"@en ;
    rdfs:domain uod-health:ElectronicHealthRecord ;
    rdfs:range uod-health:HISSystem ;
    rdfs:comment "Electronic health records are managed in the HIS"@en ;
    rdfs:comment "电子病历在 HIS 系统中管理"@zh .

uod-health:tested_in_lis a owl:ObjectProperty ;
    rdfs:label "tested in lis"@en ;
    rdfs:domain uod-health:Diagnosis ;
    rdfs:range uod-health:LISSystem ;
    rdfs:comment "Lab results are recorded in the LIS"@en ;
    rdfs:comment "检验结果在 LIS 系统中记录"@zh .

uod-health:complies_with_gmp a owl:ObjectProperty ;
    rdfs:label "complies with gmp"@en ;
    rdfs:domain uod-health:DrugProduct ;
    rdfs:range uod-health:GMPPolicy ;
    rdfs:comment "Drug manufacturing complies with GMP policy"@en ;
    rdfs:comment "药品生产遵循 GMP 规范"@zh .

