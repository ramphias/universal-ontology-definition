    rdfs:label "实验室信息系统"@zh ;
    rdfs:comment "Information system managing lab sample processing, result recording, and reporting"@en ;
    rdfs:comment "管理检验科样本处理、结果记录和报告的信息系统"@zh .

uod-health:BedOccupancyRate a owl:Class ;
    rdfs:subClassOf uod:KPI ;
    rdfs:label "Bed Occupancy Rate"@en ;
    rdfs:label "床位使用率"@zh ;
    rdfs:comment "Ratio of occupied beds to total available beds"@en ;
    rdfs:comment "实际使用床位数占开放床位总数的比率"@zh .

uod-health:ReadmissionRate a owl:Class ;
    rdfs:subClassOf uod:KPI ;
    rdfs:label "Readmission Rate"@en ;
    rdfs:label "再入院率"@zh ;
    rdfs:comment "Rate of unplanned readmissions within a defined period after discharge"@en ;
    rdfs:comment "出院后一定期间内非计划再入院的患者比率"@zh .

uod-health:ClinicalTrialSuccessRate a owl:Class ;
    rdfs:subClassOf uod:KPI ;
    rdfs:label "Clinical Trial Success Rate"@en ;
    rdfs:label "临床试验成功率"@zh ;
    rdfs:comment "Rate of clinical trials meeting primary endpoints, tracked by phase (I/II/III)"@en ;
    rdfs:comment "临床试验达到主要终点的成功比率，按阶段（I/II/III）统计"@zh .

