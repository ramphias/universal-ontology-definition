# OBJECT PROPERTIES (Relations)
# ────────────────────────────────────────

uod-manufa:has_workshop a owl:ObjectProperty ;
    rdfs:label "has workshop"@en ;
    rdfs:domain uod-manufa:Factory ;
    rdfs:range uod-manufa:Workshop ;
    rdfs:comment "A factory has workshops"@en ;
    rdfs:comment "工厂设有车间"@zh .

uod-manufa:has_production_line a owl:ObjectProperty ;
    rdfs:label "has production line"@en ;
    rdfs:domain uod-manufa:Workshop ;
    rdfs:range uod-manufa:ProductionLine ;
    rdfs:comment "A workshop contains production lines"@en ;
    rdfs:comment "车间包含产线"@zh .

uod-manufa:produces_product a owl:ObjectProperty ;
    rdfs:label "produces product"@en ;
    rdfs:domain uod-manufa:ProductionLine ;
    rdfs:range uod-manufa:ManufacturedProduct ;
    rdfs:comment "A production line produces a manufactured product"@en ;
    rdfs:comment "产线生产产品"@zh .

uod-manufa:defined_by_bom a owl:ObjectProperty ;
    rdfs:label "defined by bom"@en ;
    rdfs:domain uod-manufa:ManufacturedProduct ;
    rdfs:range uod-manufa:BillOfMaterials ;
    rdfs:comment "A product is defined by a bill of materials"@en ;
    rdfs:comment "产品由物料清单定义"@zh .

uod-manufa:consumes_material a owl:ObjectProperty ;
    rdfs:label "consumes material"@en ;
    rdfs:domain uod-manufa:WorkOrder ;
    rdfs:range uod-manufa:RawMaterial ;
    rdfs:comment "A work order consumes raw materials"@en ;
    rdfs:comment "工单消耗原材料"@zh .

uod-manufa:inspected_by a owl:ObjectProperty ;
    rdfs:label "inspected by"@en ;
    rdfs:domain uod-manufa:ManufacturedProduct ;
    rdfs:range uod-manufa:QualityInspectionReport ;
    rdfs:comment "A product is inspected and documented in a quality inspection report"@en ;
    rdfs:comment "产品经过质检"@zh .

uod-manufa:maintained_by a owl:ObjectProperty ;
    rdfs:label "maintained by"@en ;
    rdfs:domain uod-manufa:Equipment ;
    rdfs:range uod-manufa:MaintenanceOrder ;
    rdfs:comment "Equipment is maintained through maintenance orders"@en ;
    rdfs:comment "设备通过维保工单维护"@zh .

uod-manufa:supplies_to a owl:ObjectProperty ;
    rdfs:label "supplies to"@en ;
    rdfs:domain uod-manufa:Supplier ;
    rdfs:range uod-manufa:Factory ;
    rdfs:comment "A supplier provides materials to a factory"@en ;
    rdfs:comment "供应商向工厂供货"@zh .

uod-manufa:scheduled_by a owl:ObjectProperty ;
    rdfs:label "scheduled by"@en ;
    rdfs:domain uod-manufa:WorkOrder ;
    rdfs:range uod-manufa:ProductionPlanningProcess ;
    rdfs:comment "A work order is scheduled by the production planning process"@en ;
    rdfs:comment "工单由生产计划流程排程"@zh .

uod-manufa:monitored_by_mes a owl:ObjectProperty ;
    rdfs:label "monitored by mes"@en ;
    rdfs:domain uod-manufa:ProductionLine ;
    rdfs:range uod-manufa:MESSystem ;
    rdfs:comment "A production line is monitored by the MES system"@en ;
    rdfs:comment "产线由 MES 系统监控"@zh .

uod-manufa:controlled_by_scada a owl:ObjectProperty ;
    rdfs:label "controlled by scada"@en ;
    rdfs:domain uod-manufa:Equipment ;
    rdfs:range uod-manufa:SCADASystem ;
    rdfs:comment "Equipment data is collected and monitored by the SCADA system"@en ;
    rdfs:comment "设备由 SCADA 系统采集数据和监控"@zh .

