    rdfs:label "Time Tracking System"@en ;
    rdfs:label "工时管理系统"@zh ;
    rdfs:comment "A time management system for recording consultant billable hours and expense reimbursements"@en ;
    rdfs:comment "记录顾问计费时间和费用报销的工时系统"@zh .

