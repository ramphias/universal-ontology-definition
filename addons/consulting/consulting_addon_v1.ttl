    rdfs:comment "存储和检索方法论、案例库、行业报告和最佳实践的知识平台"@zh .

uod-con:ResourceManagementSystem a owl:Class ;
    rdfs:subClassOf uod:SystemApplication ;
    rdfs:label "Resource Management System"@en ;
    rdfs:label "资源管理系统"@zh ;
    rdfs:comment "A staffing system tracking consultant skills, availability, and engagement assignments"@en ;
    rdfs:comment "跟踪顾问技能、可用性和项目分配的人员配置系统"@zh .

uod-con:TimeTrackingSystem a owl:Class ;
