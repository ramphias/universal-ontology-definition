{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ramphias/universal-ontology-definition/schema/extension_schema.json",
  "title": "Industry and Domain Extension Ontology Schema",
  "description": "JSON Schema for validating L2 Industry and Domain Extension Ontology definitions",
  "type": "object",
  "required": ["layer", "version", "extends", "description", "classes", "relations", "attributes"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "layer": {
      "type": "string",
      "pattern": "^L[23]_",
      "description": "Layer identifier, must start with L2_ (industry extensions) or L3_ (enterprise customizations)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version string"
    },
    "extends": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^L1_",
          "description": "Must extend the L1 universal organization ontology"
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^L[12]_"
          },
          "minItems": 1,
          "contains": {
            "type": "string",
            "pattern": "^L1_"
          },
          "description": "Array of L1 and L2 layer IDs this extension extends; must include at least one L1"
        }
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Description of the Industry and Domain Extension"
    },
    "classes": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "label_zh", "parent", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$",
            "description": "PascalCase class identifier"
          },
          "label_zh": {
            "type": "string",
            "minLength": 1,
            "description": "Chinese label"
          },
          "label_en": {
            "type": "string",
            "description": "English label"
          },
          "parent": {
            "type": "string",
            "minLength": 1,
            "description": "Parent class ID — must reference an L1 class or another extension class"
          },
          "abstract": {
            "type": "boolean",
            "default": false,
            "description": "Whether this class is abstract (cannot be directly instantiated)"
          },
          "owner": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9-]{1,39}$"
            },
            "uniqueItems": true,
            "description": "Optional list of GitHub logins authorized to submit edits to this class via Studio. If absent or empty, role-based defaults apply (any editor can submit, admin reviews)."
          },
          "definition": {
            "type": "string",
            "minLength": 5,
            "description": "Chinese definition, at least 5 characters"
          },
          "definition_en": {
            "type": "string",
            "description": "English definition"
          }
        }
      }
    },
    "attributes": {
      "type": "array",
      "description": "Data properties (attributes) defined or extended by this layer",
      "items": {
        "type": "object",
        "required": ["id", "owner_class", "datatype", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "snake_case attribute identifier"
          },
          "owner_class": {
            "type": "string",
            "description": "Class this attribute belongs to"
          },
          "datatype": {
            "type": "string",
            "enum": ["string", "integer", "decimal", "boolean", "date", "datetime", "uri", "enum"],
            "description": "Primitive data type"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "enum_values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "definition": {
            "type": "string",
            "minLength": 5
          },
          "definition_en": {
            "type": "string"
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "domain", "range", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "snake_case relation identifier"
          },
          "domain": {
            "type": "string",
            "description": "Source class ID"
          },
          "range": {
            "type": "string",
            "description": "Target class ID"
          },
          "definition": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "sample_instances": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      }
    }
  }
}
