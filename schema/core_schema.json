{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ramphias/universal-ontology-definition/schema/core_schema.json",
  "title": "Universal Ontology Core Schema",
  "description": "JSON Schema for validating L1 Universal Enterprise Ontology Core definitions. v2.0 adds abstract classes, lifecycle status, cardinality, and deprecation tracking.",
  "type": "object",
  "required": ["metadata", "classes", "relations"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "layer", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the ontology"
        },
        "layer": {
          "type": "string",
          "pattern": "^L1_",
          "description": "Layer identifier, must start with L1_"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version string"
        },
        "license": {
          "type": "string"
        },
        "namespace": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        },
        "description_en": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "updated": {
          "type": "string",
          "format": "date",
          "description": "Last modification date"
        },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 25,
      "description": "L1 Core classes, hard capped at 25 to prevent entropy growth (Governance Rule G-01)",
      "items": {
        "type": "object",
        "required": ["id", "label_zh", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$",
            "description": "PascalCase class identifier"
          },
          "label_zh": {
            "type": "string",
            "minLength": 1,
            "description": "Chinese label"
          },
          "label_en": {
            "type": "string",
            "description": "English label"
          },
          "parent": {
            "type": ["string", "null"],
            "description": "Parent class ID or null for abstract root domains only"
          },
          "abstract": {
            "type": "boolean",
            "default": false,
            "description": "Abstract classes cannot be directly instantiated; they serve as structural groupings for inheritance"
          },
          "status": {
            "type": "string",
            "enum": ["stable", "experimental", "deprecated"],
            "default": "stable",
            "description": "Lifecycle status of this class"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Version when this class was first introduced"
          },
          "deprecated_since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Version when this class was deprecated"
          },
          "replaced_by": {
            "type": ["string", "null"],
            "description": "ID of the class that replaces this one, if deprecated"
          },
          "replaced_from": {
            "type": ["string", "null"],
            "description": "ID of the class that this one replaces"
          },
          "definition": {
            "type": "string",
            "minLength": 1,
            "description": "Chinese definition"
          },
          "definition_en": {
            "type": "string",
            "description": "English definition"
          }
        }
      }
    },
    "deprecated_classes": {
      "type": "array",
      "description": "Registry of classes removed or demoted from L1, with migration guidance",
      "items": {
        "type": "object",
        "required": ["id", "deprecated_since"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$"
          },
          "replaced_by": {
            "type": ["string", "null"],
            "description": "Replacement class ID, or null if demoted to L2"
          },
          "deprecated_since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "note": {
            "type": "string",
            "description": "Migration guidance for downstream consumers"
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "domain", "range", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "snake_case relation identifier"
          },
          "label_zh": {
            "type": "string"
          },
          "label_en": {
            "type": "string"
          },
          "domain": {
            "type": "string",
            "description": "Source class ID — prefer abstract parent classes to enable L2 reuse"
          },
          "range": {
            "type": "string",
            "description": "Target class ID — prefer abstract parent classes to enable L2 reuse"
          },
          "cardinality": {
            "type": "string",
            "enum": ["1:1", "1:N", "N:1", "N:M"],
            "default": "N:M",
            "description": "Relationship cardinality"
          },
          "inverse_of": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "ID of the inverse relation, if defined"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Version when this relation was first introduced"
          },
          "deprecated_since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "replaced_by": {
            "type": ["string", "null"]
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "definition_en": {
            "type": "string"
          }
        }
      }
    },
    "deprecated_relations": {
      "type": "array",
      "description": "Registry of relations removed or merged, with migration guidance",
      "items": {
        "type": "object",
        "required": ["id", "deprecated_since"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "replaced_by": {
            "type": ["string", "null"]
          },
          "deprecated_since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "axioms": {
      "type": "array",
      "description": "Formal semantic axioms (OWL 2-compatible) constraining classes and relations",
      "items": {
        "type": "object",
        "required": ["id", "type", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^ax_[a-z][a-z0-9_]*$",
            "description": "Axiom identifier with ax_ prefix, snake_case"
          },
          "type": {
            "type": "string",
            "enum": [
              "disjoint",
              "cardinality_min",
              "cardinality_max",
              "cardinality_exact",
              "existential",
              "universal",
              "functional",
              "inverse_functional",
              "symmetric",
              "asymmetric",
              "transitive",
              "subproperty"
            ],
            "description": "Axiom type, maps to OWL 2 construct"
          },
          "label_zh": {
            "type": "string",
            "description": "Chinese label"
          },
          "label_en": {
            "type": "string",
            "description": "English label"
          },
          "classes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[A-Z][a-zA-Z0-9]*$" },
            "minItems": 2,
            "description": "Array of class IDs (used by disjoint axioms)"
          },
          "subject_class": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$",
            "description": "The class being constrained (used by cardinality, existential, universal axioms)"
          },
          "relation": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Relation ID being constrained or characterized"
          },
          "object_class": {
            "type": "string",
            "pattern": "^[A-Z][a-zA-Z0-9]*$",
            "description": "The filler/target class (used by existential, universal axioms)"
          },
          "value": {
            "type": "integer",
            "minimum": 0,
            "description": "Cardinality value (used by cardinality_min, cardinality_max, cardinality_exact)"
          },
          "parent_relation": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Parent relation ID (used by subproperty axioms)"
          },
          "status": {
            "type": "string",
            "enum": ["stable", "experimental", "deprecated"],
            "default": "stable"
          },
          "since": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "definition": {
            "type": "string",
            "minLength": 1,
            "description": "Chinese definition"
          },
          "definition_en": {
            "type": "string",
            "description": "English definition"
          }
        }
      }
    },
    "sample_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "snake_case instance identifier"
          },
          "type": {
            "type": "string",
            "description": "Class ID this instance belongs to — must not reference abstract classes"
          },
          "label": {
            "type": "string",
            "description": "English label"
          },
          "label_zh": {
            "type": "string",
            "description": "Chinese label"
          }
        }
      }
    }
  }
}
